# Public DNS/domain for n8n webhook URLs
N8N_HOST=api.nutihealth.com
WEBHOOK_URL=https://api.nutihealth.com/

# n8n auth
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-me-prod

# PostgreSQL settings
POSTGRES_DB=n8n
POSTGRES_USER=n8n
POSTGRES_PASSWORD=change-me-db

# AI provider keys
GROQ_API_KEY=your_groq_api_key_here
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# Timezone
TZ=UTC
GENERIC_TIMEZONE=UTC
